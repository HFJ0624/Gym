<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sau.gym.admin.mapper.OrderItemMapper">

    <!--  映射查询到的字段 -->
    <resultMap id="orderItemMap" type="com.sau.gym.model.entity.order.OrderItem" autoMapping="true"></resultMap>

        <insert id="insertOrderItem">
            insert into order_item(
                order_id,
                order_no,
                goods_id,
                goods_name,
                image,
                price,
                quantity
            )values(
                       #{orderId},
                       #{orderNo},
                       #{goodsId},
                       #{goodsName},
                       #{image},
                       #{price},
                       #{quantity}
                   )
        </insert>

    <select id="getOrderById" resultMap="orderItemMap">
        select *
        from order_item
        where order_id = #{id}
    </select>

</mapper>