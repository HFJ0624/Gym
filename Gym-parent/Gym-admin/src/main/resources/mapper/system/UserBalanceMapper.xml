<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sau.gym.admin.mapper.UserBalanceMapper">

    <select id="GetBalanceById" resultType="com.sau.gym.model.entity.user.UserBalance">
        select *
        from user_balance
        where user_id = #{id}
    </select>

    <insert id="insertOne">
        insert into user_balance(
            user_id,
            balance
        )values (
            #{id},
            0
        )
    </insert>

    <update id="Recharge">
        update user_balance
        set balance = balance + #{amount},
            update_time = now()
        where user_id = #{userId}
    </update>
</mapper>