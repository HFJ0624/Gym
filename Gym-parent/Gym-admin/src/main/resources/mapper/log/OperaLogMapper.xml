<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sau.gym.admin.mapper.OperaLogMapper">

    <insert id="insert" >
        insert into oper_log (
            id,
            title,
            method,
            request_method,
            operator_type,
            oper_name,
            oper_url,
            oper_ip,
            oper_param,
            json_result,
            status,
            error_msg
        ) values (
                     #{id},
                     #{title},
                     #{method},
                     #{requestMethod},
                     #{operatorType},
                     #{operaName},
                     #{operaUrl},
                     #{operaIp},
                     #{operaParam},
                     #{jsonResult},
                     #{status},
                     #{errorMsg}
                 )
    </insert>

    <!--  映射查询到的字段 -->
    <resultMap id="operaLogMap" type="com.sau.gym.model.entity.system.OperaLog" autoMapping="true"></resultMap>


    <!-- 用于select查询公用抽取的列 -->
    <sql id="columns">
        id,title,business_type,method,request_method,operator_type,oper_name operaName,oper_url operaUrl,oper_ip operaIp,oper_param operaParam,json_result,create_time
    </sql>

    <sql id="findPageWhere">
        <where>
            <if test="title != null and title != ''">
                and title like CONCAT('%',#{title},'%')
            </if>
            <if test="operaName != null and operaName != ''">
                and operaName like CONCAT('%',#{oper_name},'%')
            </if>
            <if test="type != null and type != ''">
                and type like CONCAT('%',#{business_type},'%')
            </if>
            <if test="method != null and method != ''">
                and method like CONCAT('%',#{method},'%')
            </if>
            and is_deleted = 0
        </where>
    </sql>

    <!--  角色列表查询方法  -->
    <select id="findByPage" resultMap="operaLogMap">
        select <include refid="columns" />
        from oper_log
        <include refid="findPageWhere"/>
        order by id
    </select>

</mapper>