<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sau.gym.admin.mapper.UserMapper">

    <!-- 用于select查询公用抽取的列 -->
    <sql id="columns">
        id,username userName ,password,real_name,sex,phone,email,role,avatar,status,create_time,update_time,is_deleted
    </sql>

    <select id="selectByUserName" resultType="com.sau.gym.model.entity.user.User">
        select <include refid="columns" /> from user where username = #{userName} and is_deleted = 0
    </select>

    <sql id="findPageWhere">
        <where>
            <if test="keyword != null and keyword != ''">
                and username like CONCAT('%',#{keyword},'%')
            </if>
            <if test="createTimeBegin != null and createTimeBegin != ''">
                and create_time >= #{createTimeBegin}
            </if>
            <if test="createTimeEnd != null and createTimeEnd != ''">
                and create_time &lt;= #{createTimeEnd}
            </if>
            and is_deleted = 0
        </where>
    </sql>

    <select id="findByPage" resultType="com.sau.gym.model.entity.user.User" >
        select <include refid="columns" />
        from user
        <include refid="findPageWhere"/>
        order by id desc
    </select>

    <insert id="saveUser">
        insert into user (
            username,
            password,
            real_name,
            sex,
            phone,
            email,
            avatar
        ) values (
                     #{username},
                     #{password},
                     #{realName},
                     #{sex},
                     #{phone},
                     #{email},
                     #{avatar}
                 )
    </insert>

    <update id="updateUserStatus">
        UPDATE user SET
        status = #{status}
        WHERE id = #{id}
        and is_deleted = 0
    </update>


    <update id="updateUser">
        update user set
        <if test="username != null and username != ''">
            username = #{username},
        </if>
        <if test="password != null and password != ''">
            password = #{password},
        </if>
        <if test="realName != null and realName != ''">
            real_name = #{realName},
        </if>
        <if test="sex != null and sex != ''">
            sex = #{sex},
        </if>
        <if test="phone != null and phone != ''">
            phone = #{phone},
        </if>
        <if test="email != null and email != ''">
            email = #{email},
        </if>
        <if test="avatar != null and avatar != ''">
            avatar = #{avatar},
        </if>
        update_time =  now()
        where
        id = #{id}
    </update>

    <update id="deleteById">
        update user set
            update_time = now() ,
            is_deleted = 1
        where
            id = #{id}
    </update>

</mapper>