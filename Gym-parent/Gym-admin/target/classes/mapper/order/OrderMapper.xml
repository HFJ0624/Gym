<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sau.gym.admin.mapper.OrderMapper">

    <!--  映射查询到的字段 -->
    <resultMap id="orderMap" type="com.sau.gym.model.entity.order.Order" autoMapping="true"></resultMap>

    <sql id="findPageWhere">
        <where>
            <if test="status != null and status != ''">
                and status like CONCAT('%',#{status},'%')
            </if>
            and is_deleted = 0 and user_id = #{id}
        </where>
    </sql>

    <!--  订单列表查询方法  -->
    <select id="getOrderList" resultMap="orderMap">
        select *
        from `order`
        <include refid="findPageWhere"/>
        order by id
    </select>

    <insert id="insertOrder" useGeneratedKeys="true" keyProperty="id">
        insert into `order`(
            order_no,
            user_id,
            total_price,
            status,
            remark,
            pay_time
        )values(
                   #{orderNo},
                   #{userId},
                   #{totalPrice},
                   #{status},
                   #{remark},
                   #{payTime}
               )
    </insert>

</mapper>