<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sau.gym.admin.mapper.VenueCommentMapper">

    <!--  映射查询到的字段 -->
    <resultMap id="VenueCommentMap" type="com.sau.gym.model.entity.venue.VenueComment" autoMapping="true"></resultMap>

    <!-- 用于select查询公用抽取的列 -->
    <sql id="columns">
        vc.id,u.username,u.avatar,v.venue_name as venueName,vc.content,vc.esteem,vc.status,vc.create_time
    </sql>

    <sql id="findPageWhere">
        <where>
            <if test="venueName != null and venueName != ''">
                and v.venue_name like CONCAT('%',#{venueName},'%')
            </if>
            <if test="content != null and content != ''">
                and vc.content like CONCAT('%',#{content},'%')
            </if>
            and vc.is_deleted = 0 and v.is_deleted = 0
        </where>
    </sql>

    <select id="findByPage" resultType="com.sau.gym.model.vo.venue.VenueCommentVO">
        select <include refid="columns" />
        from venue_comment vc
        left join user u on u.id = vc.user_id
        left join venue v on v.id = vc.venue_id
        <include refid="findPageWhere"/>
        order by vc.id desc
    </select>

    <!-- 添加场馆评论 -->
    <insert id="saveVenueComment">
        insert into venue_comment (
            id,
            venue_id,
            user_id,
            content,
            esteem,
            status
        ) values (
                     #{id},
                     #{venueId},
                     #{userId},
                     #{content},
                     #{esteem},
                     #{status}
                 )
    </insert>

    <!-- 修改场馆评论 -->
    <update id="updateVenueComment">
        update venue_comment set
        <if test="content != null and content != ''">
            content = #{content},
        </if>
        <if test="esteem != null and esteem != ''">
            esteem = #{esteem},
        </if>
        update_time =  now()
        where
        id = #{id}
    </update>

    <!-- 根据id删除场馆评论 -->
    <update id="deleteById">
        update venue_comment set is_deleted = 1 where id = #{id}
    </update>

