<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sau.gym.admin.mapper.RoleMenuMapper">

    <select id="findRoleMenuByRoleId" resultType="long">
        select menu_id from role_menu where role_id = #{roleId} and is_deleted = 0 and is_half = 0
    </select>

</mapper>