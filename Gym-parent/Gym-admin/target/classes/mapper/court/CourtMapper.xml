<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sau.gym.admin.mapper.CourtMapper">

    <resultMap id="CourtMap" type="com.sau.gym.model.entity.venue.Court" autoMapping="true"></resultMap>

    <!-- 保留你原有基础结构，只修改SQL和返回字段 -->
    <sql id="columns">
        c.id,
        c.venue_id,
        c.name as name,
        c.type as type,
        c.capacity,
        c.price,
        c.create_time,
        v.venue_name as venueName,
        v.location,
        v.phone as phone
    </sql>

    <sql id="findPageWhere">
        <where>
            <if test="name != null and name != ''">
                and c.name like CONCAT('%',#{name},'%')
            </if>
            <if test="type != null and type != ''">
                and c.type like CONCAT('%',#{type},'%')
            </if>
            and c.is_deleted = 0
        </where>
    </sql>

    <!-- 直接返回结果，无需复杂ResultMap（autoMapping会自动映射别名到实体/Map） -->
    <select id="findByPage" resultType="com.sau.gym.model.vo.court.CourtVO">
        select <include refid="columns" />
        from court c
        left join venue v on c.venue_id = v.id
        <include refid="findPageWhere"/>
        order by c.id
    </select>

    <!-- 新增角色 -->
    <insert id="saveCourt">
        insert into court (
            id,
            venue_id,
            name,
            type,
            capacity,
            price
        ) values (
                     #{id},
                     #{venueId},
                     #{name},
                     #{type},
                     #{capacity},
                     #{price}
                 )
    </insert>

    <!-- 修改场馆 -->
    <update id="updateCourt">
        update court set
        <if test="venueId != null and venueId != ''">
            venue_id = #{venueId},
        </if>
        <if test="name != null and name != ''">
            name = #{name},
        </if>
        <if test="type != null and type != ''">
            type = #{type},
        </if>
        <if test="capacity != null and capacity != ''">
            capacity = #{capacity},
        </if>
        <if test="price != null and price != ''">
            price = #{price},
        </if>
        update_time =  now()
        where
        id = #{id}
    </update>

    <!-- 根据id删除场地信息 -->
    <update id="deleteById">
        update court set is_deleted = 1 where id = #{courtId}
    </update>

</mapper>